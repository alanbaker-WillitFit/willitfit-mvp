# ── Site ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://willitfit.com
NEXT_PUBLIC_SITE_NAME=WillItFit

# ── Google Sheets (CMS / data source) ───────────────
# Create a Google Cloud service account with "Viewer" access on the Sheet
# (Share the sheet with the service account's client_email).
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full private key, keeping \n escape sequences intact.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ── Analytics (structure only — not wired up in MVP) ─
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ── Revalidation ─────────────────────────────────────
# Seconds between background re-fetches of sheet data (ISR).
SHEET_REVALIDATE_SECONDS=3600
